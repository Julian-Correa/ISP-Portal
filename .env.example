# Frontend local: usar endpoint agregado local.
# En Netlify, netlify.toml define VITE_PORTAL_API_BASE=/api.
VITE_PORTAL_API_BASE=http://localhost:8787

# Backend proxy local (server/index.js) y Netlify Function
PORT=8787
CORS_ORIGIN=http://localhost:5173
# En Netlify dejar REDIS_URL vacio salvo que uses un Redis externo.
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=120
TOKEN_TTL_SECONDS=600
REQUEST_TIMEOUT_MS=12000
BODY_LIMIT=25kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

ISP_API_BASE=https://online25.ispcube.com/api
ISP_API_KEY=
ISP_CLIENT_ID=302
ISP_API_USER=
ISP_API_PASS=
